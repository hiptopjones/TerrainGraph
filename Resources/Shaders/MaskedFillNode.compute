#pragma kernel CSMain

#define MAX_FLOAT 3.402823466E+38

Texture2D<float> _InTexture;
Texture2D<float> _MaskTexture;
uint _Size;

RWTexture2D<float> _OutTexture;

[numthreads(8, 8, 1)]
void CSMain(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= _Size || id.y >= _Size)
    {
        return;
    }
    
    uint2 uv = id.xy;

    float height = _InTexture[uv].r;
    
    bool insideMask = _MaskTexture[id.xy] > 0.5;
    if (!insideMask || height != 0)
    {
        // Treat anything non-zero as a fixed value
        _OutTexture[uv].r = height;
        return;
    }
    
    // 8-neighborhood   
    int2 offsets[8] =
    {
        int2(-1, -1), int2(0, -1), int2(1, -1),
        int2(-1, 0),               int2(1, 0),
        int2(-1, 1),  int2(0, 1),  int2(1, 1)
    };

    float bestHeight = MAX_FLOAT;
    
    for (int i = 0; i < 8; i++)
    {
        int2 neighborUV = id.xy + offsets[i];
        float neighborHeight = _InTexture[neighborUV].r;

        if (neighborHeight != 0)
        {
            // Prefer the lowest height
            bestHeight = min(bestHeight, neighborHeight);
        }
    }
    
    if (bestHeight < MAX_FLOAT)
    {
        _OutTexture[uv].r = bestHeight;
    }
}
