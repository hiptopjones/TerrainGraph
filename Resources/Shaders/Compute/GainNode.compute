#pragma kernel CSMain

#include "..\Common\CommonLibrary.hlsl"

Texture2D<float> _InTexture;
float _Gain;

RWTexture2D<float> _OutTexture;

[numthreads(8, 8, 1)]
void CSMain(uint3 id : SV_DispatchThreadID)
{
    uint2 uv = id.xy;
    
    float t = saturate(_InTexture[uv].r);
    
    _OutTexture[uv].r = Gain(t, _Gain);
}
